# ─────────────────────────────────────────────────────────────
#  Veritas — Backend Environment Variables
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env — it is git-ignored.
# ─────────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────────

# Google Search API key via https://serper.dev (free tier available)
SERPER_API_KEY=your_serper_api_key_here

# SQLite (default) or PostgreSQL for multi-worker production deployments
DATABASE_URL=sqlite:///./verified_articles.db
# DATABASE_URL=postgresql://user:password@localhost:5432/veritas

# Redis connection string (must match your Redis instance)
REDIS_URL=redis://localhost:6379/0

# Comma-separated list of frontend origins allowed by CORS.
# For local dev: http://localhost:5173
# For production: https://your-frontend-domain.com
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── OPTIONAL ──────────────────────────────────────────────────

# ScrapingBee key for scraping JavaScript-heavy pages.
# The app falls back to direct HTTP download if this is unset.
# Get a free trial at https://www.scrapingbee.com
# SCRAPINGBEE_API_KEY=your_scrapingbee_api_key_here
