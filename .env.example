# ─────────────────────────────────────────────────────────────────────────────
#  Veritas — Root Environment Variables
#  Copy this file to .env and fill in real values.
#  NEVER commit .env — it is in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# Google Search API key via https://serper.dev (free tier: 2,500 queries/month)
SERPER_API_KEY=your_serper_api_key_here

# PostgreSQL connection string — REQUIRED. SQLite is not supported.
# Local dev (Postgres running in Docker on your machine):
DATABASE_URL=postgresql://veritas:veritas@localhost:5432/veritas
# Docker Compose (Postgres as a named service):
# DATABASE_URL=postgresql://veritas:veritas@postgres:5432/veritas

# Redis connection string (Celery broker + result backend + rate-limiter)
# Local dev (Redis running in Docker on your machine):
REDIS_URL=redis://localhost:6379/0
# Docker Compose (Redis as a named service):
# REDIS_URL=redis://redis:6379/0

# Comma-separated list of frontend origins allowed by CORS
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# ── OLLAMA LLM (claim verification) ──────────────────────────────────────────

# URL of the Ollama REST API — always localhost for local dev
OLLAMA_HOST=http://localhost:11434

# Model to use for NLI claim verification
# Recommended: llama3.1:8b  (best quality/speed balance, needs ~8 GB RAM)
# Alternatives: mistral:7b | llama3.2:3b (faster, lower RAM) | phi3:medium (best quality)
OLLAMA_MODEL=llama3.1:8b

# Per-claim LLM call timeout (seconds). Increase if your CPU is slow.
OLLAMA_TIMEOUT_SECONDS=60

# ── OPTIONAL ──────────────────────────────────────────────────────────────────

# ScrapingBee key — for JS-rendered pages (e.g. paywalled articles).
# Falls back to newspaper3k direct download if not set.
# SCRAPINGBEE_API_KEY=your_scrapingbee_api_key_here

# WebSocket result timeout (seconds). After this, the browser falls back to polling.
# WS_TIMEOUT_SECONDS=180
