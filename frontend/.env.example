# ─────────────────────────────────────────────────────────────
#  Veritas — Frontend Environment Variables (Example)
#  Copy this file to frontend/.env and fill in your values.
#  NEVER commit .env — it is git-ignored.
# ─────────────────────────────────────────────────────────────

# ── LOCAL DEVELOPMENT ──────────────────────────────────────────
# Leave both empty in dev mode.
# The Vite dev server proxies /api and /ws automatically (see vite.config.js).
VITE_API_BASE_URL=
VITE_WS_URL=

# ── PRODUCTION BUILD ───────────────────────────────────────────
# Set these to your deployed backend URLs before running: npm run build
#
# REST API base (no trailing slash):
# VITE_API_BASE_URL=https://api.yourveritas.com
#
# WebSocket base (ws:// or wss://):
# VITE_WS_URL=wss://api.yourveritas.com
