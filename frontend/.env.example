# ─────────────────────────────────────────────────────────────
#  Veritas — Frontend Environment Variables
#  Copy this file to frontend/.env and fill in your values.
#  NEVER commit .env — it is git-ignored.
# ─────────────────────────────────────────────────────────────

# ── LOCAL DEVELOPMENT ─────────────────────────────────────────
# Leave VITE_API_BASE_URL empty (or omit it entirely).
# The Vite dev server proxies /api → http://localhost:8000 automatically.
VITE_API_BASE_URL=

# ── PRODUCTION BUILD ──────────────────────────────────────────
# Set this to the full URL of your deployed backend before running:
#   npm run build
# Example:
# VITE_API_BASE_URL=https://api.yourdomain.com
